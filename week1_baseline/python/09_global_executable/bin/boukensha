#!/usr/bin/env python3
"""The ``boukensha`` executable — port of Ruby's ``bin/boukensha``.

Makes the standalone loader importable, then hands off to it. The loader decides
which step's ``boukensha`` package to load and boots the REPL.
"""

import sys
from pathlib import Path

# The step directory (this file lives in <step>/bin/boukensha).
sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

import boukensha_loader  # noqa: E402

boukensha_loader.load_and_start_repl()
